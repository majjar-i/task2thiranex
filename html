<!-- index.html -->

<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8">
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <!-- SEO -->
  <meta
    name="description"
    content="Responsive portfolio website using HTML5 and CSS3"
  >

  <title>Responsive Portfolio</title>

  <link rel="stylesheet" href="style.css">

</head>

<body>

  <!-- Accessibility -->
  <a href="#main-content" class="skip-link">
    Skip to Main Content
  </a>

  <div class="container">

    <!-- Sidebar -->
    <aside>

      <div class="profile">
        <img
          src="https://via.placeholder.com/120"
          alt="Profile picture"
        >

        <h2>Tharun</h2>
        <p>Frontend Developer</p>
      </div>

      <div class="skills">
        <h3>Skills</h3>

        <ul>
          <li>HTML5</li>
          <li>CSS3</li>
          <li>JavaScript</li>
          <li>Responsive Design</li>
        </ul>
      </div>

    </aside>

    <!-- Main Content -->
    <div class="main-content">

      <!-- Header -->
      <header>

        <nav aria-label="Main Navigation">

          <div class="logo">
            Portfolio
          </div>

          <ul class="nav-links">
            <li><a href="#about">About</a></li>
            <li><a href="#projects">Projects</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>

        </nav>

      </header>

      <!-- Main -->
      <main id="main-content">

        <!-- Hero -->
        <section class="hero">

          <div class="hero-content">
            <h1>Hello, I'm Tharun</h1>

            <p>
              Web Development Intern &
              Frontend Developer
            </p>
          </div>

        </section>

        <!-- About -->
        <section id="about">

          <h2 class="section-title">
            About Me
          </h2>

          <p>
            I create responsive, accessible,
            and modern websites using
            semantic HTML5 and advanced CSS3.
          </p>

        </section>

        <!-- Projects -->
        <section id="projects">

          <h2 class="section-title">
            Projects
          </h2>

          <div class="projects-grid">

            <article class="project-card">
              <h3>Portfolio Website</h3>

              <p>
                Fully responsive portfolio
                using CSS Grid and Flexbox.
              </p>
            </article>

            <article class="project-card">
              <h3>Landing Page</h3>

              <p>
                SEO-friendly modern landing page.
              </p>
            </article>

            <article class="project-card">
              <h3>Dashboard UI</h3>

              <p>
                Responsive admin dashboard layout.
              </p>
            </article>

          </div>

        </section>

        <!-- Contact -->
        <section id="contact">

          <h2 class="section-title">
            Contact Me
          </h2>

          <form
            class="contact-form"
            aria-label="Contact Form"
          >

            <div class="form-group">
              <label for="name">Name</label>

              <input
                type="text"
                id="name"
                required
              >
            </div>

            <div class="form-group">
              <label for="email">Email</label>

              <input
                type="email"
                id="email"
                required
              >
            </div>

            <div class="form-group">
              <label for="message">Message</label>

              <textarea
                id="message"
                rows="5"
                required
              ></textarea>
            </div>

            <button type="submit">
              Send Message
            </button>

          </form>

        </section>

      </main>

      <!-- Footer -->
      <footer>
        <p>
          © 2026 Tharun Portfolio.
          All Rights Reserved.
        </p>
      </footer>

    </div>

  </div>

</body>
</html>
